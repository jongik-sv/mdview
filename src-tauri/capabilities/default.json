{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "/**" }, { "path": "**" }, { "path": "$HOME/**" }]
    },
    "dialog:default",
    "clipboard-manager:allow-write-text"
  ]
}
